<?xml version="1.0" ?>
<sdf version="1.5">
  <world name="default">
    <!-- A global light source -->
    <include>
      <uri>model://sun</uri>
    </include>
    <!-- A ground plane -->
    <include>
      <uri>model://ground_plane</uri>
    </include>
    <!-- Our custom grasp plugin -->
    <plugin name="grasp_plugin" filename="libgrasp_plugin.so"/>
  </world>
</sdf>
